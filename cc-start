#!/bin/bash
# Start a new Claude Code instance or attach to existing one
# Usage: ./cc-start [instance-name] [--branch branch-name] [--port [port-number]] [--tmux] [--repo autodex|opendex]
# If no name provided, generates a random name like "happy-tiger"
# No port forwarding by default. Use --port to expose a dev server port (default: 3000).
# --repo selects which repo to clone into the container (default: autodex from .env).

set -e

# Determine script directory early (needed for sourcing .env and finding project files)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source .env to read project configuration (GIT_REPO_URL, NPM_INSTALL_DIR, etc.)
if [ -f "$SCRIPT_DIR/.env" ]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

# Pin the Claude Code CLI version installed at start time. Keep this in sync with
# build.sh. Bump to upgrade (or set CLAUDE_CODE_VERSION=latest to track upstream).
CLAUDE_CODE_VERSION="${CLAUDE_CODE_VERSION:-2.1.154}"

emit_desktop_input_ready_marker() {
    if [ "${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" = "1" ]; then
        printf '\033]1337;AutodexInputReady\a'
    fi
}

sync_opendex_key() {
    local source_key="$HOME/.ssh/openclawcodex.pem"
    local target_dir="$SCRIPT_DIR/git-data/.ssh"
    local target_key="$target_dir/openclawcodex.pem"

    if [ ! -f "$source_key" ]; then
        echo "  (openclawcodex.pem not found; skipping remote OpenClaw key sync)"
        return 0
    fi

    mkdir -p "$target_dir"
    if ! install -m 600 "$source_key" "$target_key" 2>/dev/null; then
        echo "  (Could not sync openclawcodex.pem, continuing anyway...)"
    fi
}

# Keep Claude Code current whenever cc-start is used. Mirrors update_codex_cli in
# codex-start, but uses the native installer (which installs into the node user's
# ~/.local/bin), so it runs as the default container user rather than root.
update_claude_cli() {
    local container_name="$1"

    if [ "${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" = "1" ] && [ "${CLAUDE_AUTO_UPDATE:-}" != "true" ]; then
        echo "  Skipping Claude Code CLI auto-update during Desktop startup"
        return 0
    fi

    echo "  Ensuring Claude Code CLI is at ${CLAUDE_CODE_VERSION}..."
    if docker exec "$container_name" sh -lc "curl -fsSL https://claude.ai/install.sh | bash -s -- ${CLAUDE_CODE_VERSION}" >/tmp/claude-update.log 2>&1; then
        local claude_version
        claude_version=$(docker exec "$container_name" sh -lc "claude --version 2>/dev/null | head -n 1" 2>/dev/null || true)
        if [ -n "$claude_version" ]; then
            echo "  ✓ Claude Code CLI ready: $claude_version"
        else
            echo "  ✓ Claude Code CLI updated"
        fi
    else
        echo "  ⚠ Could not auto-update Claude Code CLI (continuing with installed version)"
        sed "s/^/    /" /tmp/claude-update.log | tail -n 20 || true
    fi
}

# Parse arguments
INSTANCE_NAME=""
GIT_BRANCH_OVERRIDE=""
PORT_OVERRIDE=""
USE_TMUX="false"
REPO_OVERRIDE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --branch)
            GIT_BRANCH_OVERRIDE="$2"
            shift 2
            ;;
        --port)
            # If next arg is a number, use it; otherwise default to 3000
            if [[ -n "$2" && "$2" =~ ^[0-9]+$ ]]; then
                PORT_OVERRIDE="$2"
                shift 2
            else
                PORT_OVERRIDE="3000"
                shift
            fi
            ;;
        --tmux)
            USE_TMUX="true"
            shift
            ;;
        --repo)
            REPO_OVERRIDE="$2"
            shift 2
            ;;
        *)
            INSTANCE_NAME="$1"
            shift
            ;;
    esac
done

# Resolve repo key to a concrete git URL. Empty or "autodex" keeps the .env default.
RESOLVED_REPO_URL=""
case "$REPO_OVERRIDE" in
    ""|autodex)
        REPO_OVERRIDE="autodex"
        ;;
    opendex)
        RESOLVED_REPO_URL="git@github.com:decisional/opendex.git"
        ;;
    *)
        echo "⚠ Unknown --repo '$REPO_OVERRIDE' (expected: autodex, opendex). Falling back to default." >&2
        REPO_OVERRIDE="autodex"
        ;;
esac

# Get instance name from argument or generate a random one
if [ -z "$INSTANCE_NAME" ]; then
    # Generate a nice random name (adjective-noun combination)
    ADJECTIVES=(happy swift clever bright calm cool bold quick wise gentle noble proud brave kind)
    NOUNS=(tiger lion eagle fox wolf bear hawk deer owl raven falcon dolphin dragon phoenix)

    # Get random indices
    ADJ_INDEX=$((RANDOM % ${#ADJECTIVES[@]}))
    NOUN_INDEX=$((RANDOM % ${#NOUNS[@]}))

    INSTANCE_NAME="${ADJECTIVES[$ADJ_INDEX]}-${NOUNS[$NOUN_INDEX]}"
fi

PROJECT_NAME="claude-${INSTANCE_NAME}"
CONTAINER_NAME="${PROJECT_NAME}-claude-code-1"

echo "🚀 Starting Claude Code instance: $INSTANCE_NAME"
echo "   Project: $PROJECT_NAME"
echo "   Repo: $REPO_OVERRIDE"
if [ -n "$PORT_OVERRIDE" ]; then
    echo "   Dev port: $PORT_OVERRIDE"
fi
echo ""

# Build extra flags for docker-compose run
RUN_EXTRA_FLAGS=""
if [ -n "$GIT_BRANCH_OVERRIDE" ]; then
    RUN_EXTRA_FLAGS="$RUN_EXTRA_FLAGS -e GIT_BRANCH=$GIT_BRANCH_OVERRIDE"
    echo "📌 Using branch: $GIT_BRANCH_OVERRIDE"
    echo ""
fi
if [ -n "$PORT_OVERRIDE" ]; then
    RUN_EXTRA_FLAGS="$RUN_EXTRA_FLAGS -e DEV_PORT=$PORT_OVERRIDE --publish $PORT_OVERRIDE:$PORT_OVERRIDE"
fi
if [ "$USE_TMUX" = "true" ]; then
    RUN_EXTRA_FLAGS="$RUN_EXTRA_FLAGS -e USE_TMUX=true"
fi
if [ -n "$RESOLVED_REPO_URL" ]; then
    # Override GIT_REPO_URL for this container; clear GIT_CLONE_DIR so entrypoint
    # falls back to basename(url) for the target directory.
    RUN_EXTRA_FLAGS="$RUN_EXTRA_FLAGS -e GIT_REPO_URL=$RESOLVED_REPO_URL -e GIT_CLONE_DIR="
    echo "📦 Overriding repo: $RESOLVED_REPO_URL"
    echo ""
fi
if [ -n "$HOST_MOUNT_DIR" ] && [ -d "$HOST_MOUNT_DIR" ]; then
    RUN_EXTRA_FLAGS="$RUN_EXTRA_FLAGS -v ${HOST_MOUNT_DIR}:${HOST_MOUNT_DIR}:ro"
    echo "📂 Mounting host directory: $HOST_MOUNT_DIR"
    echo ""
fi

if [ "$REPO_OVERRIDE" = "opendex" ]; then
    sync_opendex_key
fi

# Check if container already exists and is running
if docker ps -q -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
    echo "✓ Container already running"

    echo ""
    update_claude_cli "$CONTAINER_NAME"

    # Copy Claude instructions if they exist locally
    if [ -f "$HOME/.claude/CLAUDE.md" ]; then
        echo "  Copying Claude instructions..."
        docker-compose -p "$PROJECT_NAME" exec -T claude-code mkdir -p /home/node/.claude
        docker cp "$HOME/.claude/CLAUDE.md" "${CONTAINER_NAME}:/home/node/.claude/CLAUDE.md"
    fi

    # Copy skills from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/skills" ]; then
        echo "  Copying skills..."
        docker cp "$SCRIPT_DIR/.claude/skills/." "${CONTAINER_NAME}:/home/node/.claude/skills/"
    fi

    # Copy commands from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/commands" ]; then
        echo "  Copying commands..."
        docker cp "$SCRIPT_DIR/.claude/commands/." "${CONTAINER_NAME}:/home/node/.claude/commands/"
    fi

    # Copy settings.json from repo if it exists
    if [ -f "$SCRIPT_DIR/.claude/settings.json" ]; then
        echo "  Copying settings..."
        docker cp "$SCRIPT_DIR/.claude/settings.json" "${CONTAINER_NAME}:/home/node/.claude/settings.json"
    fi

    # Copy project .env file if PROJECT_ENV_FILE path is configured in .env.
    # Only for the autodex repo — other repos don't use the autodex project env.
    if [ "$REPO_OVERRIDE" = "autodex" ] && [ -n "$PROJECT_ENV_FILE" ] && [ -f "$PROJECT_ENV_FILE" ]; then
        # Determine destination inside container
        if [ -n "$GIT_CLONE_DIR" ]; then
            REPO_DIR="$GIT_CLONE_DIR"
        elif [ -n "$GIT_REPO_URL" ]; then
            REPO_DIR=$(basename "$GIT_REPO_URL" .git)
        fi
        if [ -n "$REPO_DIR" ]; then
            ENV_DEST_DIR="${PROJECT_ENV_DEST:-$NPM_INSTALL_DIR}"
            if [ -n "$ENV_DEST_DIR" ]; then
                ENV_DEST="/workspace/$REPO_DIR/$ENV_DEST_DIR/.env"
            else
                ENV_DEST="/workspace/$REPO_DIR/.env"
            fi
            echo "  Copying project .env to $ENV_DEST..."
            docker exec "${CONTAINER_NAME}" rm -f "$ENV_DEST" 2>/dev/null || true
            cat "$PROJECT_ENV_FILE" | docker exec -i "${CONTAINER_NAME}" tee "$ENV_DEST" > /dev/null
        fi
    fi

    echo "  Connecting to existing instance..."
    echo ""
    if [ "$USE_TMUX" = "true" ]; then
        # Fast re-attach: if the container already has a tmux session, attach
        # directly instead of re-running the full entrypoint (which re-checks
        # credentials, git status, etc. and can get stuck).
        if docker exec "$CONTAINER_NAME" tmux has-session -t llm-session 2>/dev/null; then
            echo "🔄 Reattaching to existing tmux session..."
            echo ""
            emit_desktop_input_ready_marker
            docker-compose -p "$PROJECT_NAME" exec -it claude-code tmux -u attach-session -d -t llm-session
        else
            # No tmux session — run entrypoint to start a fresh one
            docker-compose -p "$PROJECT_NAME" exec -e USE_TMUX="$USE_TMUX" -e AUTODEX_DESKTOP_INPUT_READY_MARKER="${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" -it claude-code /entrypoint.sh claude
        fi
    else
        docker-compose -p "$PROJECT_NAME" exec -e USE_TMUX="$USE_TMUX" -e AUTODEX_DESKTOP_INPUT_READY_MARKER="${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" -it claude-code /entrypoint.sh claude
    fi
else
    # Check if container exists but is stopped
    if docker ps -aq -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
        echo "✓ Container exists but stopped"
        echo "  Starting existing container..."
        docker-compose -p "$PROJECT_NAME" start
    else
        echo "✓ Creating new container..."
        docker-compose -p "$PROJECT_NAME" run -d --name "$CONTAINER_NAME" $RUN_EXTRA_FLAGS claude-code tail -f /dev/null

        # Wait for initial repository setup to complete
        # Dependency installation will continue in background
        echo ""
        echo "⏳ Setting up repository..."
        echo ""

        # Follow logs until clone/pull is complete
        docker logs -f "$CONTAINER_NAME" 2>&1 | while IFS= read -r line; do
            echo "   $line"
            # Break when clone is complete - let dependencies install in background
            if echo "$line" | grep -q "Repository cloned successfully!"; then
                break
            fi
            # Break when pre-cloned repo is ready (pull completed)
            if echo "$line" | grep -q "Repository ready (pre-cloned)"; then
                break
            fi
            # Also handle case where no git repo is configured
            if echo "$line" | grep -q "No git repository configured"; then
                break
            fi
        done

        echo ""
        echo "✓ Repository ready"
        echo "  (Dependencies are installing in background)"
    fi

    echo ""
    update_claude_cli "$CONTAINER_NAME"

    echo ""

    # Copy Claude instructions if they exist locally
    if [ -f "$HOME/.claude/CLAUDE.md" ]; then
        echo "  Copying Claude instructions..."
        docker cp "$HOME/.claude/CLAUDE.md" "${CONTAINER_NAME}:/home/node/.claude/CLAUDE.md" 2>/dev/null || echo "  (Could not copy instructions, continuing anyway...)"
    fi

    # Copy skills from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/skills" ]; then
        echo "  Copying skills..."
        docker cp "$SCRIPT_DIR/.claude/skills/." "${CONTAINER_NAME}:/home/node/.claude/skills/" 2>/dev/null || echo "  (Could not copy skills, continuing anyway...)"
    fi

    # Copy commands from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/commands" ]; then
        echo "  Copying commands..."
        docker cp "$SCRIPT_DIR/.claude/commands/." "${CONTAINER_NAME}:/home/node/.claude/commands/" 2>/dev/null || echo "  (Could not copy commands, continuing anyway...)"
    fi

    # Copy settings.json from repo if it exists
    if [ -f "$SCRIPT_DIR/.claude/settings.json" ]; then
        echo "  Copying settings..."
        docker cp "$SCRIPT_DIR/.claude/settings.json" "${CONTAINER_NAME}:/home/node/.claude/settings.json" 2>/dev/null || echo "  (Could not copy settings, continuing anyway...)"
    fi

    # Copy project .env file if PROJECT_ENV_FILE path is configured in .env.
    # Only for the autodex repo — other repos don't use the autodex project env.
    if [ "$REPO_OVERRIDE" = "autodex" ] && [ -n "$PROJECT_ENV_FILE" ] && [ -f "$PROJECT_ENV_FILE" ]; then
        if [ -n "$GIT_CLONE_DIR" ]; then
            REPO_DIR="$GIT_CLONE_DIR"
        elif [ -n "$GIT_REPO_URL" ]; then
            REPO_DIR=$(basename "$GIT_REPO_URL" .git)
        fi
        if [ -n "$REPO_DIR" ]; then
            ENV_DEST_DIR="${PROJECT_ENV_DEST:-$NPM_INSTALL_DIR}"
            if [ -n "$ENV_DEST_DIR" ]; then
                ENV_DEST="/workspace/$REPO_DIR/$ENV_DEST_DIR/.env"
            else
                ENV_DEST="/workspace/$REPO_DIR/.env"
            fi
            echo "  Copying project .env to $ENV_DEST..."
            docker exec "${CONTAINER_NAME}" rm -f "$ENV_DEST" 2>/dev/null || true
            cat "$PROJECT_ENV_FILE" | docker exec -i "${CONTAINER_NAME}" tee "$ENV_DEST" > /dev/null
        fi
    fi

    echo "  Launching Claude Code..."
    echo ""
    docker-compose -p "$PROJECT_NAME" exec -e USE_TMUX="$USE_TMUX" -e AUTODEX_DESKTOP_INPUT_READY_MARKER="${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" -it claude-code /entrypoint.sh claude
fi
