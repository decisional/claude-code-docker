#!/bin/bash
# Resume/connect to an existing Claude Code instance via tmux
# Usage: ./cc-exec [instance-name] [--reset]
# If no name provided, uses current directory name

set -e

INSTANCE_NAME=""
RESET_TO_MAIN=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --reset)
            RESET_TO_MAIN=true
            shift
            ;;
        *)
            INSTANCE_NAME="$1"
            shift
            ;;
    esac
done

if [ -z "$INSTANCE_NAME" ]; then
    INSTANCE_NAME=$(basename "$(pwd)")
fi

PROJECT_NAME="claude-${INSTANCE_NAME}"
CONTAINER_NAME="${PROJECT_NAME}-claude-code-1"
TMUX_SESSION_NAME="claude"
SESSION_LOG_PATH="/home/node/.claude/session-monitors/${CONTAINER_NAME}.log"

echo "🔌 Connecting to Claude Code instance: $INSTANCE_NAME"
echo ""

ensure_tmux_available() {
    if ! docker exec "$CONTAINER_NAME" sh -lc "command -v tmux >/dev/null 2>&1"; then
        echo "❌ tmux is not available in this container image."
        echo "   Rebuild with './build.sh', then recreate this instance."
        exit 1
    fi
}

start_or_reset_tmux_session() {
    docker exec "$CONTAINER_NAME" sh -lc "mkdir -p /home/node/.claude/session-monitors"
    if [ "$RESET_TO_MAIN" = true ]; then
        echo "  Resetting session to latest main..."
        docker exec "$CONTAINER_NAME" sh -lc "tmux kill-session -t '$TMUX_SESSION_NAME' 2>/dev/null || true"
        docker exec -e RESET_TO_MAIN=true "$CONTAINER_NAME" sh -lc "tmux new-session -d -s '$TMUX_SESSION_NAME' '/entrypoint.sh claude'"
    elif ! docker exec "$CONTAINER_NAME" tmux has-session -t "$TMUX_SESSION_NAME" >/dev/null 2>&1; then
        docker exec "$CONTAINER_NAME" sh -lc "tmux new-session -d -s '$TMUX_SESSION_NAME' '/entrypoint.sh claude'"
    fi
    docker exec "$CONTAINER_NAME" sh -lc "tmux pipe-pane -o -t '$TMUX_SESSION_NAME' \"cat >> '$SESSION_LOG_PATH'\""
}

# Check if container exists and is running
if docker ps -q -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
    ensure_tmux_available
    start_or_reset_tmux_session
    echo "  Attaching to Claude session (detach: Ctrl-b d)..."
    echo ""
    docker exec -it "$CONTAINER_NAME" tmux attach -t "$TMUX_SESSION_NAME"
else
    if docker ps -aq -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
        echo "❌ Container exists but is not running"
        echo "   Use './cc-start $INSTANCE_NAME' to start it"
    else
        echo "❌ No container found for instance: $INSTANCE_NAME"
        echo "   Use './cc-start $INSTANCE_NAME' to create it"
        echo ""
        echo "Available instances:"
        docker ps -a --filter "name=claude-" --format "  - {{.Names}}" | sed 's/-claude-code-1//' | sed 's/claude-//'
    fi
    exit 1
fi
