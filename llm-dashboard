SCRIPT_DIR = Path(__file__).resolve().parent
CLAUDE_LOG_DIR = SCRIPT_DIR / "claude-data" / "session-monitors"
CODEX_LOG_DIR = SCRIPT_DIR / "codex-data" / "session-monitors"
CLAUDE_PROJECTS_DIR = SCRIPT_DIR / "claude-data" / "projects"
CODEX_SESSIONS_DIR = SCRIPT_DIR / "codex-data" / "sessions"

ANSI_RE = re.compile(r"\x1B\[[0-?]*[ -/]*[@-~]")


@dataclass
class ParsedSessionFile:
    path: Path
    mtime: float
    cwd: str
    branch: str
    timestamp: str
    text: str


class SessionFileCache:
    def __init__(self) -> None:
        self._cache: dict[Path, ParsedSessionFile | None] = {}

    def get(self, path: Path, parser: Any) -> ParsedSessionFile | None:
        try:
            mtime = path.stat().st_mtime
        except OSError:
            return None

        cached = self._cache.get(path)
        if cached is not None and cached.mtime == mtime:
            return cached

        parsed = parser(path)
        if parsed is not None:
            parsed.mtime = mtime
        self._cache[path] = parsed
        return parsed


CLAUDE_CACHE = SessionFileCache()
CODEX_CACHE = SessionFileCache()
DEEP_MESSAGE_SCAN = os.environ.get("LLM_DASHBOARD_DEEP_MESSAGE_SCAN", "0") == "1"


def run_cmd(args: list[str], timeout: int = 4) -> tuple[int, str, str]:
    try:
        proc = subprocess.run(args, capture_output=True, text=True, timeout=timeout, check=False)
    except (subprocess.TimeoutExpired, FileNotFoundError) as exc:
        return 1, "", str(exc)
    return proc.returncode, proc.stdout.strip(), proc.stderr.strip()


def docker_exec(container: str, shell_script: str, timeout: int = 4) -> tuple[int, str, str]:
    return run_cmd(["docker", "exec", container, "sh", "-lc", shell_script], timeout=timeout)


def safe_text(text: str, limit: int = 220) -> str:
    normalized = ANSI_RE.sub("", text).replace("\r", "")
    normalized = " ".join(normalized.split())
    if len(normalized) <= limit:
        return normalized
    return normalized[: limit - 1] + "…"


def derive_instance_name(container_name: str) -> str:
    name = container_name
    if name.endswith("-claude-code-1"):
        name = name[: -len("-claude-code-1")]
    if name.startswith("claude-"):
        name = name[len("claude-") :]
    if name.startswith("codex-"):
        name = name[len("codex-") :]
    return name


def container_type(container_name: str) -> str:
    if container_name.startswith("claude-"):
        return "claude"
    if container_name.startswith("codex-"):
        return "codex"
    return ""


def tmux_session_name(container_name: str) -> str:
    llm_type = container_type(container_name)
    return llm_type if llm_type else ""


def is_valid_container_name(name: str) -> bool:
    return bool(re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9_.-]*", name))


def resolve_tmux_target_pane(container: str, session_name: str) -> str:
    """Pick the pane most likely running the interactive LLM UI."""
    rc, out, _ = run_cmd(
        [
            "docker",
            "exec",
            container,
            "tmux",
            "list-panes",
            "-t",
            session_name,
            "-F",
            "#{pane_id}\t#{pane_active}\t#{pane_current_command}\t#{window_index}\t#{pane_index}\t#{pane_dead}",
        ],
        timeout=4,
    )
    if rc != 0 or not out:
        return session_name

    best_target = session_name
    best_score = -1
    for raw in out.splitlines():
        parts = raw.split("\t")
        if len(parts) != 6:
            continue
        pane_id, pane_active, pane_command, window_index, pane_index, pane_dead = parts
        if pane_dead == "1":
            continue

        score = 0
        if pane_command in {"node", "codex", "claude"}:
            score += 100
        if pane_active == "1":
            score += 25
        if window_index == "0":
            score += 5
        if pane_index == "0":
            score += 3

        if score > best_score:
            best_score = score
            best_target = pane_id or session_name

    return best_target


def collect_container_names() -> list[str]:
    names: set[str] = set()
    for prefix in ("claude-", "codex-"):
        rc, out, _ = run_cmd(["docker", "ps", "-a", "--filter", f"name={prefix}", "--format", "{{.Names}}"])
        if rc == 0 and out:
            for line in out.splitlines():
                line = line.strip()
                if line:
                    names.add(line)
    return sorted(names)


def inspect_running(container: str) -> bool:
    rc, out, _ = run_cmd(["docker", "inspect", "-f", "{{.State.Running}}", container])
    return rc == 0 and out.strip() == "true"


def inspect_started_at(container: str) -> str:
    rc, out, _ = run_cmd(["docker", "inspect", "-f", "{{.State.StartedAt}}", container])
    return out.strip() if rc == 0 else ""


def file_mtime_epoch(path: Path) -> int | None:
    try:
        return int(path.stat().st_mtime)
    except OSError:
        return None


def parse_proc_info(proc_info: str) -> dict[str, str]:
    values = {"pid": "", "state": "", "wchan": "", "children": "0"}
    for token in proc_info.split():
        if "=" not in token:
            continue
        key, value = token.split("=", 1)
        if key in values:
            values[key] = value
    return values


def get_proc_info(container: str, llm_type: str) -> dict[str, str]:
    script = textwrap.dedent(
        fr"""
        llm_type='{llm_type}'
        pid=''
        for proc_cmdline in /proc/[0-9]*/cmdline; do
            cmd=$(tr '\\0' ' ' < "$proc_cmdline" 2>/dev/null || true)
            case "$llm_type:$cmd" in
                claude:*" claude --"*|claude:claude\ --*|claude:*"/claude --"*|claude:*" /home/node/.local/bin/claude --"*)
                    pid=${{proc_cmdline#/proc/}}
                    pid=${{pid%/cmdline}}
                    break
                    ;;
                codex:*"/codex/codex --"*|codex:*" /usr/local/bin/codex --"*)
                    pid=${{proc_cmdline#/proc/}}
                    pid=${{pid%/cmdline}}
                    break
                    ;;
            esac
        done

        if [ -z "$pid" ]; then
            echo 'pid= state= wchan= children=0'
            exit 0
        fi

        proc_state=$(awk '{{print $3}}' /proc/$pid/stat 2>/dev/null || echo '?')
        wchan=$(cat /proc/$pid/wchan 2>/dev/null || echo '')
        children=0
        for proc_stat in /proc/[0-9]*/stat; do
            ppid=$(awk '{{print $4}}' "$proc_stat" 2>/dev/null || echo '')
            if [ "$ppid" = "$pid" ]; then
                children=$((children + 1))
            fi
        done

        echo "pid=$pid state=$proc_state wchan=$wchan children=$children"
        """
    ).strip()
    rc, out, _ = docker_exec(container, script)
    if rc != 0:
        return {"pid": "", "state": "", "wchan": "", "children": "0"}
    return parse_proc_info(out)


def get_repo_and_branch(container: str) -> tuple[str, str]:
    script = textwrap.dedent(
        """
        repo=''
        if [ -n "$GIT_CLONE_DIR" ] && [ -d "/workspace/$GIT_CLONE_DIR/.git" ]; then
            repo="/workspace/$GIT_CLONE_DIR"
        elif [ -n "$GIT_REPO_URL" ]; then
            repo_name=$(basename "$GIT_REPO_URL" .git)
            if [ -d "/workspace/$repo_name/.git" ]; then
                repo="/workspace/$repo_name"
            fi
        fi

        if [ -z "$repo" ]; then
            for d in /workspace/*; do
                [ -d "$d/.git" ] || continue
                repo="$d"
                break
            done
        fi

        if [ -n "$repo" ]; then
            branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
            printf 'repo=%s\n' "$repo"
            printf 'branch=%s\n' "$branch"
        fi
        """
    ).strip()
    rc, out, _ = docker_exec(container, script)
    if rc != 0 or not out:
        return "", ""

    repo = ""
    branch = ""
    for line in out.splitlines():
        if line.startswith("repo="):
            repo = line[len("repo=") :].strip()
        elif line.startswith("branch="):
            branch = line[len("branch=") :].strip()
    return repo, branch


def capture_tmux_pane(container: str, target: str, history_lines: int = 220, keep_ansi: bool = False) -> tuple[int, str]:
    start = f"-{max(20, history_lines)}"
    capture_cmd = ["docker", "exec", container, "tmux", "capture-pane"]
    if keep_ansi:
        capture_cmd.append("-e")
    capture_cmd.extend(["-p", "-t", target, "-S", start])
    rc, out, _ = run_cmd(capture_cmd)
    return rc, out


def get_tmux_pane_lines(container: str, target: str, history_lines: int = 220, max_lines: int = 120) -> list[str]:
    rc, out = capture_tmux_pane(container=container, target=target, history_lines=history_lines)
    if rc != 0:
        return []

    lines = []
    for raw in out.splitlines():
        line = safe_text(raw, limit=400)
        if not line:
            continue
        if set(line) == {"─"}:
            continue
        lines.append(line)
    if max_lines > 0:
        return lines[-max_lines:]
    return lines


def get_tmux_pane_preview(container: str, target: str) -> list[str]:
    lines = get_tmux_pane_lines(container=container, target=target, history_lines=140, max_lines=120)
    return lines[-14:]


def codex_prompt_still_contains_message(container: str, target: str, message: str) -> bool:
    """Detect if Codex still has an unsent draft after one submit keypress."""
    last_line = message.splitlines()[-1].strip() if message.splitlines() else ""
    if not last_line:
        return False

    rc, raw = capture_tmux_pane(container=container, target=target, history_lines=80, keep_ansi=True)
    if rc != 0 or not raw:
        return False

    for line in reversed(raw.splitlines()[-24:]):
        normalized = ANSI_RE.sub("", line).replace("\r", "")
        if last_line not in normalized:
            continue
        # Unsent prompt line renders as bold prompt (`1m`), while submitted history
        # uses dim prompt styling (`1;2m`) in Codex.
        if ("\x1b[1m›" in line or "\x1b[0;1m›" in line) and "\x1b[1;2m›" not in line:
            return True
        return False

    return False


def read_recent_jsonl_files(base_dir: Path, limit: int = 120) -> list[Path]:
    if not base_dir.exists():
        return []
    files = [p for p in base_dir.rglob("*.jsonl") if p.is_file()]
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return files[:limit]


def extract_content_text(content: Any) -> str:
    if isinstance(content, str):
        return safe_text(content)

    if isinstance(content, list):
        parts: list[str] = []
        for item in content:
            if not isinstance(item, dict):
                continue
            item_type = item.get("type")
            if item_type in {"text", "input_text"}:
                text = item.get("text")
                if isinstance(text, str) and text.strip():
                    parts.append(text.strip())
            elif item_type == "tool_result":
                continue
        if parts:
            return safe_text(" ".join(parts))

    return ""


def parse_claude_session_file(path: Path) -> ParsedSessionFile | None:
    latest_timestamp = ""
    latest_text = ""
    latest_cwd = ""
    latest_branch = ""

    try:
        with path.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue

                if obj.get("type") != "user":
                    continue
                message = obj.get("message") or {}
                if message.get("role") != "user":
                    continue

                text = extract_content_text(message.get("content"))
                if not text:
                    continue

                timestamp = str(obj.get("timestamp") or "")
                cwd = str(obj.get("cwd") or "")
                branch = str(obj.get("gitBranch") or "")
                if timestamp >= latest_timestamp:
                    latest_timestamp = timestamp
                    latest_text = text
                    latest_cwd = cwd
                    latest_branch = branch
    except OSError:
        return None

    if not latest_text:
        return None

    return ParsedSessionFile(path=path, mtime=0.0, cwd=latest_cwd, branch=latest_branch, timestamp=latest_timestamp, text=latest_text)


def parse_codex_session_file(path: Path) -> ParsedSessionFile | None:
    cwd = ""
    latest_timestamp = ""
    latest_text = ""

    try:
        with path.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    continue

                if obj.get("type") == "session_meta":
                    payload = obj.get("payload") or {}
                    if isinstance(payload, dict):
                        meta_cwd = payload.get("cwd")
                        if isinstance(meta_cwd, str):
                            cwd = meta_cwd
                    continue

                if obj.get("type") != "response_item":
                    continue
                payload = obj.get("payload") or {}
                if not isinstance(payload, dict):
                    continue
                if payload.get("type") != "message" or payload.get("role") != "user":
                    continue

                text = extract_content_text(payload.get("content"))
                if not text:
                    continue

                timestamp = str(obj.get("timestamp") or "")
                if timestamp >= latest_timestamp:
                    latest_timestamp = timestamp
                    latest_text = text
    except OSError:
        return None

    if not latest_text:
        return None

    return ParsedSessionFile(path=path, mtime=0.0, cwd=cwd, branch="", timestamp=latest_timestamp, text=latest_text)


def find_last_user_message(llm_type: str, repo: str, branch: str, fallback_preview: list[str]) -> str:
    if not DEEP_MESSAGE_SCAN:
        for line in reversed(fallback_preview):
            line = line.strip()
            if line and len(line) > 3 and not line.startswith("• Ran"):
                return safe_text(line)
        return ""

    if llm_type == "claude":
        candidates = read_recent_jsonl_files(CLAUDE_PROJECTS_DIR, limit=25)
        best: ParsedSessionFile | None = None
        for path in candidates:
            parsed = CLAUDE_CACHE.get(path, parse_claude_session_file)
            if parsed is None:
                continue
            if repo and parsed.cwd and parsed.cwd != repo:
                continue
            if branch and parsed.branch and parsed.branch != branch:
                continue
            if best is None or parsed.timestamp >= best.timestamp:
                best = parsed
        if best is not None:
            return best.text

    if llm_type == "codex":
        candidates = read_recent_jsonl_files(CODEX_SESSIONS_DIR, limit=30)
        best = None
        for path in candidates:
            parsed = CODEX_CACHE.get(path, parse_codex_session_file)
            if parsed is None:
                continue
            if repo and parsed.cwd and parsed.cwd != repo:
                continue
            if best is None or parsed.timestamp >= best.timestamp:
                best = parsed
        if best is not None:
            return best.text

    for line in reversed(fallback_preview):
        if line and len(line) > 3 and not line.startswith("• Ran"):
            return safe_text(line)

    return ""


def classify_state(
    container: str,
    llm_type: str,
    running: bool,
    wait_threshold_seconds: int,
    now_epoch: int,
) -> tuple[str, int | None, dict[str, str], bool]:
    session_name = llm_type

    if llm_type == "claude":
        log_path = CLAUDE_LOG_DIR / f"{container}.log"
    else:
        log_path = CODEX_LOG_DIR / f"{container}.log"

    if not running:
        return "stopped", None, {"pid": "", "state": "", "wchan": "", "children": "0"}, False

    rc, _, _ = docker_exec(container, "command -v tmux >/dev/null 2>&1")
    if rc != 0:
        return "no-tmux", None, {"pid": "", "state": "", "wchan": "", "children": "0"}, False

    rc, _, _ = run_cmd(["docker", "exec", container, "tmux", "has-session", "-t", session_name])
    if rc != 0:
        return "legacy-no-session", None, {"pid": "", "state": "", "wchan": "", "children": "0"}, False

    proc = get_proc_info(container, llm_type)
    pid = proc.get("pid", "")
    children = int(proc.get("children", "0") or "0")
    proc_state = proc.get("state", "")
    wchan = proc.get("wchan", "")

    idle_seconds: int | None = None
    log_mtime = file_mtime_epoch(log_path)
    if log_mtime is not None:
        idle_seconds = max(0, now_epoch - log_mtime)

    if not pid:
        return "starting", idle_seconds, proc, True

    if children > 0:
        return "running", idle_seconds, proc, True

    if idle_seconds is not None and idle_seconds >= wait_threshold_seconds:
        return "waiting-input", idle_seconds, proc, True

    if idle_seconds is not None:
        return "running", idle_seconds, proc, True

    if proc_state == "S" and wchan == "do_epoll_wait":
        return "waiting-input", idle_seconds, proc, True

    return "running", idle_seconds, proc, True


def collect_status(wait_threshold_seconds: int = 45) -> dict[str, Any]:
    container_names = collect_container_names()
    now_epoch = int(dt.datetime.now().timestamp())
    generated_at = dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")

    items: list[dict[str, Any]] = []

    for container in container_names:
        if container.startswith("claude-"):
            llm_type = "claude"
        elif container.startswith("codex-"):
            llm_type = "codex"
        else:
            continue

        running = inspect_running(container)
        state, idle_seconds, proc, tmux_ready = classify_state(
            container=container,
            llm_type=llm_type,
            running=running,
            wait_threshold_seconds=wait_threshold_seconds,
            now_epoch=now_epoch,
        )

        repo_path = ""
        branch = ""
        pane_preview: list[str] = []
        pane_target = llm_type
        if running:
            repo_path, branch = get_repo_and_branch(container)
        if tmux_ready:
            pane_target = resolve_tmux_target_pane(container, llm_type)
            pane_preview = get_tmux_pane_preview(container, pane_target)

        last_user_message = find_last_user_message(llm_type, repo_path, branch, pane_preview)
        instance = derive_instance_name(container)
        reconnect_cmd = f"./cc-exec {instance}" if llm_type == "claude" else f"./codex-exec {instance}"
        cmd_prefix = "cc" if llm_type == "claude" else "codex"

        item = {
            "type": llm_type,
            "instance": derive_instance_name(container),
            "container": container,
            "running": running,
            "state": state,
            "idle_seconds": idle_seconds,
            "repo_path": repo_path,
            "branch": branch,
            "started_at": inspect_started_at(container),
            "last_user_message": last_user_message,
            "pane_preview": pane_preview,
            "process": proc,
            "commands": {
                "reconnect": reconnect_cmd,
                "reset": reconnect_cmd + " --reset",
                "shell": f"./{cmd_prefix}-shell {instance}",
                "stop": f"./{cmd_prefix}-stop {instance}",
            },
            "pane_target": pane_target,
        }
        items.append(item)

    waiting_count = sum(1 for item in items if item["state"] == "waiting-input")
    return {
        "generated_at": generated_at,
        "wait_threshold_seconds": wait_threshold_seconds,
        "waiting_count": waiting_count,
        "total_count": len(items),
        "containers": items,
    }


def pane_snapshot(container: str, max_lines: int = 120) -> dict[str, Any]:
    if not is_valid_container_name(container):
        return {"ok": False, "error": "invalid container"}

    llm_type = container_type(container)
    if not llm_type:
        return {"ok": False, "error": "unsupported container type"}

    session = tmux_session_name(container)
    if not session:
        return {"ok": False, "error": "unsupported container type"}

    if not inspect_running(container):
        return {"ok": False, "error": "container is not running"}

    rc, _, _ = run_cmd(["docker", "exec", container, "tmux", "has-session", "-t", session], timeout=3)
    if rc != 0:
        return {"ok": False, "error": "tmux session not found"}

    target = resolve_tmux_target_pane(container, session)
    lines = get_tmux_pane_lines(container=container, target=target, history_lines=260, max_lines=max_lines)
    return {
        "ok": True,
        "container": container,
        "session": session,
        "pane_target": target,
        "timestamp": dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
        "preview_lines": lines,
    }


def send_chat_message(container: str, message: str) -> tuple[bool, str]:
    if not is_valid_container_name(container):
        return False, "invalid container"

    llm_type = container_type(container)
    if not llm_type:
        return False, "unsupported container type"

    session = tmux_session_name(container)
    if not inspect_running(container):
        return False, "container is not running"

    rc, _, _ = run_cmd(["docker", "exec", container, "tmux", "has-session", "-t", session], timeout=3)
    if rc != 0:
        return False, "tmux session not found"
    target = resolve_tmux_target_pane(container, session)

    message = message.replace("\r\n", "\n").replace("\r", "\n").rstrip("\n")
    if not message:
        return False, "message is empty"

    lines = message.splitlines() or [message]
    for idx, line in enumerate(lines):
        if line:
            rc, _out, err = run_cmd(["docker", "exec", container, "tmux", "send-keys", "-t", target, "-l", line], timeout=4)
            if rc != 0:
                return False, err or "failed to send message"
        if idx < len(lines) - 1:
            rc, _out, err = run_cmd(["docker", "exec", container, "tmux", "send-keys", "-t", target, "C-m"], timeout=4)
            if rc != 0:
                return False, err or "failed to send message"

    rc, _out, err = run_cmd(["docker", "exec", container, "tmux", "send-keys", "-t", target, "C-m"], timeout=4)
    if rc != 0:
        return False, err or "failed to send message"

    # Codex occasionally keeps the draft in the prompt after one submit key.
    # If we detect that state, send one more submit keypress.
    if llm_type == "codex" and codex_prompt_still_contains_message(container, target, message):
        rc, _out, err = run_cmd(["docker", "exec", container, "tmux", "send-keys", "-t", target, "C-m"], timeout=4)
        if rc != 0:
            return False, err or "failed to confirm message submit"

    return True, ""


