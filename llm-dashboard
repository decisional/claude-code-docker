      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: 0 6px 20px rgba(26, 35, 28, 0.08);
    }
    .header {
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }
    .title {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.01em;
    }
    .meta {
      color: var(--muted);
      font-size: 13px;
    }
    .controls {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
      color: var(--muted);
    }
    .table-wrap {
      overflow: auto;
      max-height: calc(100vh - 110px);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      font-size: 13px;
    }
    thead th {
      text-align: left;
      color: var(--muted);
      font-weight: 600;
      background: #fbfdfb;
      position: sticky;
      top: 0;
      z-index: 2;
      border-bottom: 1px solid var(--line);
    }
    th, td {
      padding: 10px 10px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    tbody tr { cursor: pointer; }
    tbody tr:hover { background: #f8fbf9; }
    tbody tr.selected { background: #edf6f4; }
    .mono {
      font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 2px 8px;
      background: var(--pill);
      border: 1px solid var(--line);
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
    }
    .pill.running { color: var(--ok); border-color: #b7e2c4; background: #ebf9f0; }
    .pill.waiting-input { color: var(--wait); border-color: #f2b8b5; background: #fdeceb; }
    .pill.starting { color: #1d4ed8; border-color: #bcd0ff; background: #eef4ff; }
    .pill.stopped { color: #6b7280; }
    .pill.no-tmux, .pill.legacy-no-session { color: var(--warn); border-color: #f3d19f; background: #fff7eb; }
    .detail {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-height: calc(100vh - 32px);
      overflow: auto;
    }
    .detail h2 {
      margin: 0;
      font-size: 17px;
    }
    .kv {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 6px 10px;
      font-size: 13px;
    }
    .kv .k { color: var(--muted); }
    .preview {
      white-space: pre-wrap;
      background: #f7faf8;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 10px;
      font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
      max-height: 240px;
      overflow: auto;
    }
    .cmds {
      display: grid;
      gap: 8px;
    }
    .cmd {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      border: 1px solid var(--line);
      background: #fcfefd;
      border-radius: 8px;
      padding: 8px;
      font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
    }
    button {
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #ffffff;
      color: var(--ink);
      cursor: pointer;
      font-size: 12px;
      padding: 5px 8px;
    }
    button:hover { border-color: #a8b7ac; }
    textarea {
      width: 100%;
      min-height: 78px;
      resize: vertical;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 8px;
      font-family: "SFMono-Regular", Menlo, Monaco, Consolas, monospace;
      font-size: 12px;
      background: #ffffff;
      color: var(--ink);
    }
    .row {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .row button {
      white-space: nowrap;
    }
    .status {
      color: var(--muted);
      font-size: 12px;
    }
    .hint {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }
    @media (max-width: 1180px) {
      .layout { grid-template-columns: 1fr; }
      .table-wrap { max-height: 52vh; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <section class="card">
      <div class="header">
        <div>
          <div class="title">LLM Session Dashboard</div>
          <div class="meta" id="metaLine">Loading...</div>
        </div>
        <div class="controls">
          <label><input id="waitingOnly" type="checkbox" /> waiting only</label>
          <button id="refreshBtn">Refresh</button>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="width:78px">Type</th>
              <th style="width:150px">Instance</th>
              <th style="width:140px">State</th>
              <th style="width:120px">Branch</th>
              <th style="width:76px">Idle(s)</th>
              <th>Last User Message</th>
            </tr>
          </thead>
          <tbody id="rows"></tbody>
        </table>
      </div>
    </section>

    <aside class="card">
      <div class="detail" id="detail">
        <h2>No Session Selected</h2>
        <div class="hint">Click a row to inspect branch, last message, pane preview, and reconnect commands.</div>
      </div>
    </aside>
  </div>

  <script>
    const rowsEl = document.getElementById('rows');
    const detailEl = document.getElementById('detail');
    const metaLineEl = document.getElementById('metaLine');
    const waitingOnlyEl = document.getElementById('waitingOnly');
    const refreshBtnEl = document.getElementById('refreshBtn');
    const FETCH_TIMEOUT_MS = 9000;

    let state = { items: [], selected: null, generatedAt: null };
    let paneStream = null;
    let streamContainer = null;

    function esc(text) {
      return (text || '').replace(/[&<>"]/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[ch]));
    }

    function pillClass(status) {
      return `pill ${status || ''}`;
    }

    function formatIdle(value) {
      if (value === null || value === undefined) return '-';
      return String(value);
    }

    function copyText(value) {
      navigator.clipboard.writeText(value).catch(() => {});
    }

    function closePaneStream() {
      if (paneStream) {
        paneStream.close();
        paneStream = null;
      }
      streamContainer = null;
    }

    function startPaneStream(container) {
      if (!container) {
        closePaneStream();
        return;
      }
      if (paneStream && streamContainer === container) {
        return;
      }
      closePaneStream();

      streamContainer = container;
      const url = `/api/stream?container=${encodeURIComponent(container)}`;
      paneStream = new EventSource(url);

      paneStream.onmessage = event => {
        let payload = null;
        try {
          payload = JSON.parse(event.data);
        } catch (_err) {
          return;
        }

        const paneEl = document.getElementById('livePane');
        const streamMetaEl = document.getElementById('streamMeta');
        if (!paneEl || !streamMetaEl) return;

        if (!payload.ok) {
          streamMetaEl.textContent = `stream error: ${payload.error || 'unknown error'}`;
          return;
        }

        const lines = payload.preview_lines || [];
        paneEl.textContent = lines.length ? lines.join('\\n') : '(no pane output)';
        streamMetaEl.textContent = `live stream: ${payload.timestamp || ''}`;
      };

      paneStream.onerror = () => {
        const streamMetaEl = document.getElementById('streamMeta');
        if (streamMetaEl) {
          streamMetaEl.textContent = 'stream disconnected';
        }
      };
    }

    async function sendChatMessage(container) {
      const inputEl = document.getElementById('chatInput');
      const statusEl = document.getElementById('chatStatus');
      const sendBtn = document.getElementById('chatSendBtn');
      if (!inputEl || !statusEl || !sendBtn) return;

      const message = (inputEl.value || '').trim();
      if (!message) return;

      sendBtn.disabled = true;
      statusEl.textContent = 'sending...';
      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ container, message }),
        });
        const payload = await response.json();
        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || 'send failed');
        }
        inputEl.value = '';
        statusEl.textContent = 'sent';
      } catch (err) {
        statusEl.textContent = `send failed: ${err.message || 'unknown error'}`;
      } finally {
        sendBtn.disabled = false;
      }
    }

    function renderDetail(item) {
      if (!item) {
        closePaneStream();
        detailEl.innerHTML = '<h2>No Session Selected</h2><div class="hint">Click a row to inspect branch, last message, pane preview, and reconnect commands.</div>';
        return;
      }

      const previewText = (item.pane_preview || []).join('\\n');
      const commandRows = Object.entries(item.commands || {}).map(([name, cmd]) => {
        return `<div class="cmd"><span>${esc(cmd)}</span><button data-copy="${esc(cmd)}">Copy</button></div>`;
      }).join('');

      detailEl.innerHTML = `
        <h2>${esc(item.instance)} <span class="pill ${item.state}">${esc(item.state)}</span></h2>
        <div class="kv">
          <div class="k">Type</div><div>${esc(item.type)}</div>
          <div class="k">Container</div><div class="mono">${esc(item.container)}</div>
          <div class="k">Branch</div><div class="mono">${esc(item.branch || '-')}</div>
          <div class="k">Repo</div><div class="mono">${esc(item.repo_path || '-')}</div>
          <div class="k">Idle</div><div>${esc(formatIdle(item.idle_seconds))}</div>
          <div class="k">Started</div><div class="mono">${esc(item.started_at || '-')}</div>
          <div class="k">Last User</div><div>${esc(item.last_user_message || '-')}</div>
        </div>
        <div>
          <div class="k" style="margin-bottom:6px; color: var(--muted); font-size:12px;">Live Session Output</div>
          <div id="streamMeta" class="status" style="margin-bottom:6px;">connecting stream...</div>
          <div id="livePane" class="preview">${esc(previewText || '(no pane output)')}</div>
        </div>
        <div>
          <div class="k" style="margin-bottom:6px; color: var(--muted); font-size:12px;">Send Message</div>
          <textarea id="chatInput" placeholder="Type your message to ${esc(item.type)}..."></textarea>
          <div class="row" style="margin-top:8px; margin-bottom:4px;">
            <button id="chatSendBtn">Send To Session</button>
            <div id="chatStatus" class="status">Enter sends to active tmux session.</div>
          </div>
        </div>
        <div>
          <div class="k" style="margin-bottom:6px; color: var(--muted); font-size:12px;">Commands</div>
          <div class="cmds">${commandRows}</div>
        </div>
        <div class="hint">Reconnect commands attach to tmux. Detach with <span class="mono">Ctrl-b d</span>.</div>
      `;

      detailEl.querySelectorAll('button[data-copy]').forEach(btn => {
        btn.addEventListener('click', event => {
          event.stopPropagation();
          copyText(btn.getAttribute('data-copy') || '');
        });
      });

      const sendBtn = document.getElementById('chatSendBtn');
      const chatInput = document.getElementById('chatInput');
      if (sendBtn && chatInput) {
        sendBtn.addEventListener('click', () => sendChatMessage(item.container));
        chatInput.addEventListener('keydown', event => {
          if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            sendChatMessage(item.container);
          }
        });
      }

      startPaneStream(item.container);
    }

    function renderRows() {
      const waitingOnly = waitingOnlyEl.checked;
      const shown = state.items.filter(item => !waitingOnly || item.state === 'waiting-input');

      rowsEl.innerHTML = shown.map(item => {
        const selected = state.selected === item.container ? 'selected' : '';
        return `
          <tr class="${selected}" data-container="${esc(item.container)}">
            <td><span class="pill">${esc(item.type)}</span></td>
            <td class="mono">${esc(item.instance)}</td>
            <td><span class="${pillClass(item.state)}">${esc(item.state)}</span></td>
            <td class="mono">${esc(item.branch || '-')}</td>
            <td>${esc(formatIdle(item.idle_seconds))}</td>
            <td>${esc(item.last_user_message || '-')}</td>
          </tr>
        `;
      }).join('');

      rowsEl.querySelectorAll('tr').forEach(tr => {
        tr.addEventListener('click', () => {
          const container = tr.getAttribute('data-container');
          state.selected = container;
          renderRows();
          renderDetail(state.items.find(item => item.container === container));
        });
      });

      if (!shown.length) {
        rowsEl.innerHTML = '<tr><td colspan="6" class="hint" style="padding: 16px;">No matching sessions.</td></tr>';
      }
    }

    function renderErrorRow(message) {
      rowsEl.innerHTML = `<tr><td colspan="6" class="hint" style="padding: 16px; color: #b91c1c;">${esc(message)}</td></tr>`;
    }

    async function refresh() {
      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);
      try {
        const response = await fetch('/api/status', { cache: 'no-store', signal: controller.signal });
        if (!response.ok) throw new Error('request failed');
        const data = await response.json();
        state.items = data.containers || [];
        state.generatedAt = data.generated_at;

        if (!state.selected && state.items.length) {
          state.selected = state.items[0].container;
        }

        const selectedItem = state.items.find(item => item.container === state.selected) || null;
        metaLineEl.textContent = `Updated ${data.generated_at || '-'} | waiting ${data.waiting_count}/${data.total_count}`;
        renderRows();
        renderDetail(selectedItem);
      } catch (_err) {
        metaLineEl.textContent = 'Failed to load dashboard data';
        renderErrorRow('Status request failed or timed out. Keep dashboard running and check docker access.');
      } finally {
        clearTimeout(timer);
      }
    }

    waitingOnlyEl.addEventListener('change', renderRows);
    refreshBtnEl.addEventListener('click', refresh);
    window.addEventListener('beforeunload', closePaneStream);

    refresh();
    setInterval(refresh, 8000);
  </script>
</body>
</html>
"""


class DashboardHandler(BaseHTTPRequestHandler):
    wait_threshold_seconds = 45
    _last_payload: dict[str, Any] | None = None
    _last_payload_ts: float = 0.0

    def log_message(self, _fmt: str, *_args: Any) -> None:
        return

    def _write_json(self, payload: dict[str, Any], status: int = 200) -> None:
        body = json.dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _write_html(self, body: str, status: int = 200) -> None:
        data = body.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _write_json_error(self, error: str, status: int = 400) -> None:
        self._write_json({"ok": False, "error": error}, status=status)

    def _read_json_body(self) -> dict[str, Any] | None:
        raw_length = self.headers.get("Content-Length", "0")
        try:
            length = int(raw_length)
        except ValueError:
            return None
        if length <= 0 or length > 64_000:
            return None
        raw = self.rfile.read(length)
        try:
            parsed = json.loads(raw.decode("utf-8"))
        except (UnicodeDecodeError, json.JSONDecodeError):
            return None
        return parsed if isinstance(parsed, dict) else None

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        path = parsed.path

        if path == "/":
            self._write_html(build_html())
            return

        if path == "/api/status":
            now = time.time()
            if self._last_payload is not None and (now - self._last_payload_ts) < 4.0:
                payload = self._last_payload
            else:
                payload = collect_status(wait_threshold_seconds=self.wait_threshold_seconds)
                DashboardHandler._last_payload = payload
                DashboardHandler._last_payload_ts = now
            self._write_json(payload)
            return

        if path == "/api/pane":
            query = parse_qs(parsed.query)
            container = (query.get("container", [""])[0] or "").strip()
            payload = pane_snapshot(container, max_lines=120)
            status = 200 if payload.get("ok") else 400
            self._write_json(payload, status=status)
            return

        if path == "/api/stream":
            query = parse_qs(parsed.query)
            container = (query.get("container", [""])[0] or "").strip()
            if not is_valid_container_name(container):
                self._write_json_error("invalid container", status=400)
                return

            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.send_header("X-Accel-Buffering", "no")
            self.end_headers()

            try:
                while True:
                    payload = pane_snapshot(container, max_lines=120)
                    chunk = f"data: {json.dumps(payload)}\\n\\n".encode("utf-8")
                    self.wfile.write(chunk)
                    self.wfile.flush()
                    time.sleep(1.0)
            except (BrokenPipeError, ConnectionResetError, TimeoutError):
                pass
            return

        self._write_html("Not found", status=404)

    def do_POST(self) -> None:
        parsed = urlparse(self.path)
        path = parsed.path

        if path != "/api/chat":
            self._write_json_error("not found", status=404)
            return

        payload = self._read_json_body()
        if payload is None:
            self._write_json_error("invalid JSON body", status=400)
            return

        container = str(payload.get("container", "")).strip()
        message = str(payload.get("message", ""))

        if not is_valid_container_name(container):
            self._write_json_error("invalid container", status=400)
            return
        if not message.strip():
            self._write_json_error("message is empty", status=400)
            return
        if len(message) > 12_000:
            self._write_json_error("message too large (max 12000 chars)", status=400)
            return

        ok, err = send_chat_message(container=container, message=message)
        if not ok:
            self._write_json_error(err or "failed to send message", status=400)
            return

        self._write_json({"ok": True, "container": container})


class QuietThreadingHTTPServer(ThreadingHTTPServer):
    def handle_error(self, _request: Any, _client_address: Any) -> None:
        _, exc, _ = sys.exc_info()
        if isinstance(exc, (ConnectionResetError, BrokenPipeError, TimeoutError)):
            return
        super().handle_error(_request, _client_address)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run a local dashboard for Claude/Codex container sessions")
    parser.add_argument("--host", default="127.0.0.1", help="Bind host (default: 127.0.0.1)")
    parser.add_argument("--port", type=int, default=8765, help="Bind port (default: 8765)")
    parser.add_argument(
        "--wait-threshold-seconds",
        type=int,
        default=int(os.environ.get("LLM_WAIT_THRESHOLD_SECONDS", "45")),
        help="Idle threshold to classify waiting-input (default: 45)",
    )
    parser.add_argument("--once", action="store_true", help="Print one JSON snapshot and exit")
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if args.once:
        payload = collect_status(wait_threshold_seconds=args.wait_threshold_seconds)
        print(json.dumps(payload, indent=2))
        return 0

    DashboardHandler.wait_threshold_seconds = args.wait_threshold_seconds
    server = QuietThreadingHTTPServer((args.host, args.port), DashboardHandler)
    print(f"Dashboard listening on http://{args.host}:{args.port}")
    print("Press Ctrl-C to stop")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
