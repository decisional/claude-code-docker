{
  "name": "claude-code-docker-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop session manager for Claude Code and Codex Docker containers",
  "author": "Decisional",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "node -e \"require('fs').writeFileSync('electron/build-info.json', JSON.stringify({repoPath: require('path').resolve(__dirname, '..')}))\" && vite build",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.decisional.claude-code-desktop",
    "productName": "Autodex Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": true
    },
    "dmg": {
      "title": "Autodex Desktop",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  }
}
