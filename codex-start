#!/bin/bash
# Start a new Codex CLI instance or attach to existing one
# Usage: ./codex-start [instance-name] [--branch branch-name] [--tmux] [--repo autodex|opendex]
# If no name provided, generates a random name like "happy-tiger"
# --repo selects which repo to clone into the container (default: autodex from .env).

set -e

# Determine script directory early (needed for sourcing .env and finding project files)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source .env to read project configuration (GIT_REPO_URL, NPM_INSTALL_DIR, etc.)
if [ -f "$SCRIPT_DIR/.env" ]; then
    set -a
    source "$SCRIPT_DIR/.env"
    set +a
fi

emit_desktop_input_ready_marker() {
    if [ "${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" = "1" ]; then
        printf '\033]1337;AutodexInputReady\a'
    fi
}

sync_opendex_key() {
    local source_key="$HOME/.ssh/openclawcodex.pem"
    local target_dir="$SCRIPT_DIR/git-data/.ssh"
    local target_key="$target_dir/openclawcodex.pem"

    if [ ! -f "$source_key" ]; then
        echo "  (openclawcodex.pem not found; skipping remote OpenClaw key sync)"
        return 0
    fi

    mkdir -p "$target_dir"
    if ! install -m 600 "$source_key" "$target_key" 2>/dev/null; then
        echo "  (Could not sync openclawcodex.pem, continuing anyway...)"
    fi
}

is_semver() {
    [[ "${1:-}" =~ ^[0-9]+[.][0-9]+[.][0-9]+(-[0-9A-Za-z._-]+)?$ ]]
}

detect_host_codex_version() {
    local version=""

    if command -v npm >/dev/null 2>&1; then
        version=$(npm list -g @openai/codex --depth=0 2>/dev/null | sed -n 's/.*@openai\/codex@\([^[:space:]]*\).*/\1/p' | head -n 1)
    fi

    if ! is_semver "$version" && command -v codex >/dev/null 2>&1; then
        version=$(codex --version 2>/dev/null | awk '{print $NF; exit}' | sed 's/^v//')
    fi

    if is_semver "$version"; then
        printf '%s' "$version"
    fi
}

# Keep Codex current whenever codex-start creates or starts a Codex process.
update_codex_cli() {
    local container_name="$1"

    case "${CODEX_AUTO_UPDATE:-true}" in
        false|FALSE|0|no|NO)
            echo "  Skipping Codex CLI auto-update (CODEX_AUTO_UPDATE=${CODEX_AUTO_UPDATE})"
            return 0
            ;;
    esac

    if docker exec "$container_name" tmux has-session -t llm-session 2>/dev/null; then
        echo "  Skipping Codex CLI auto-update; existing tmux session is running"
        return 0
    fi

    local host_version
    local package_spec="@openai/codex@latest"
    host_version=$(detect_host_codex_version)
    if [ -n "$host_version" ]; then
        package_spec="@openai/codex@$host_version"
    fi

    local timeout_seconds="${CODEX_AUTO_UPDATE_TIMEOUT_SECONDS:-90}"
    if ! [[ "$timeout_seconds" =~ ^[0-9]+$ ]] || [ "$timeout_seconds" -lt 1 ]; then
        timeout_seconds=90
    fi

    local update_log="/tmp/codex-update.log"
    echo "  Updating Codex CLI (${package_spec}, timeout ${timeout_seconds}s)..."
    if docker exec \
        -u 0 \
        -e npm_config_update_notifier=false \
        -e npm_config_fund=false \
        -e npm_config_audit=false \
        "$container_name" \
        timeout "${timeout_seconds}s" npm install -g "$package_spec" --no-fund --no-audit --loglevel=warn >"$update_log" 2>&1; then
        local codex_version
        codex_version=$(docker exec "$container_name" sh -lc "codex --version 2>/dev/null | head -n 1" 2>/dev/null || true)
        if [ -n "$codex_version" ]; then
            echo "  ✓ Codex CLI ready: $codex_version"
        else
            echo "  ✓ Codex CLI updated"
        fi
    else
        local exit_code=$?
        echo "  ⚠ Could not auto-update Codex CLI (continuing with installed version)"
        if [ "$exit_code" -eq 124 ]; then
            echo "    Update timed out after ${timeout_seconds}s"
        fi
        sed "s/^/    /" "$update_log" | tail -n 20 || true
    fi
}

# Parse arguments
INSTANCE_NAME=""
GIT_BRANCH_OVERRIDE=""
USE_TMUX="false"
REPO_OVERRIDE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --branch)
            GIT_BRANCH_OVERRIDE="$2"
            shift 2
            ;;
        --tmux)
            USE_TMUX="true"
            shift
            ;;
        --repo)
            REPO_OVERRIDE="$2"
            shift 2
            ;;
        *)
            INSTANCE_NAME="$1"
            shift
            ;;
    esac
done

# Resolve repo key to a concrete git URL. Empty or "autodex" keeps the .env default.
RESOLVED_REPO_URL=""
case "$REPO_OVERRIDE" in
    ""|autodex)
        REPO_OVERRIDE="autodex"
        ;;
    opendex)
        RESOLVED_REPO_URL="git@github.com:decisional/opendex.git"
        ;;
    *)
        echo "⚠ Unknown --repo '$REPO_OVERRIDE' (expected: autodex, opendex). Falling back to default." >&2
        REPO_OVERRIDE="autodex"
        ;;
esac

# Get instance name from argument or generate a random one
if [ -z "$INSTANCE_NAME" ]; then
    # Generate a nice random name (adjective-noun combination)
    ADJECTIVES=(happy swift clever bright calm cool bold quick wise gentle noble proud brave kind)
    NOUNS=(tiger lion eagle fox wolf bear hawk deer owl raven falcon dolphin dragon phoenix)

    # Get random indices
    ADJ_INDEX=$((RANDOM % ${#ADJECTIVES[@]}))
    NOUN_INDEX=$((RANDOM % ${#NOUNS[@]}))

    INSTANCE_NAME="${ADJECTIVES[$ADJ_INDEX]}-${NOUNS[$NOUN_INDEX]}"
fi

PROJECT_NAME="codex-${INSTANCE_NAME}"
CONTAINER_NAME="${PROJECT_NAME}-claude-code-1"

echo "🚀 Starting Codex CLI instance: $INSTANCE_NAME"
echo "   Project: $PROJECT_NAME"
echo "   Repo: $REPO_OVERRIDE"
echo ""

# Sync Codex credentials from host to codex-data (mounted into container)
if [ -f "$HOME/.codex/auth.json" ]; then
    cp "$HOME/.codex/auth.json" "$SCRIPT_DIR/codex-data/auth.json"
    chmod 600 "$SCRIPT_DIR/codex-data/auth.json"
    echo "✓ Synced Codex credentials from host"
fi
if [ -f "$HOME/.codex/config.toml" ]; then
    cp "$HOME/.codex/config.toml" "$SCRIPT_DIR/codex-data/config.toml"
    echo "✓ Synced Codex config from host"
fi
echo ""

# Build environment override for branch if specified
ENV_OVERRIDE="-e LLM_TYPE=codex -e USE_TMUX=$USE_TMUX -e npm_config_update_notifier=false -e NO_UPDATE_NOTIFIER=1"
VOLUME_OVERRIDE=""
if [ -n "${AUTODEX_DESKTOP_INPUT_READY_MARKER:-}" ]; then
    ENV_OVERRIDE="$ENV_OVERRIDE -e AUTODEX_DESKTOP_INPUT_READY_MARKER=$AUTODEX_DESKTOP_INPUT_READY_MARKER"
fi
if [ -n "$GIT_BRANCH_OVERRIDE" ]; then
    ENV_OVERRIDE="$ENV_OVERRIDE -e GIT_BRANCH=$GIT_BRANCH_OVERRIDE"
    echo "📌 Using branch: $GIT_BRANCH_OVERRIDE"
    echo ""
fi
if [ -n "$RESOLVED_REPO_URL" ]; then
    # Override GIT_REPO_URL for this container; clear GIT_CLONE_DIR so entrypoint
    # falls back to basename(url) for the target directory.
    ENV_OVERRIDE="$ENV_OVERRIDE -e GIT_REPO_URL=$RESOLVED_REPO_URL -e GIT_CLONE_DIR="
    echo "📦 Overriding repo: $RESOLVED_REPO_URL"
    echo ""
fi
if [ -n "$HOST_MOUNT_DIR" ] && [ -d "$HOST_MOUNT_DIR" ]; then
    VOLUME_OVERRIDE="-v ${HOST_MOUNT_DIR}:${HOST_MOUNT_DIR}:ro"
    echo "📂 Mounting host directory: $HOST_MOUNT_DIR"
    echo ""
fi

if [ "$REPO_OVERRIDE" = "opendex" ]; then
    sync_opendex_key
fi

# Check if container already exists and is running
if docker ps -q -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
    echo "✓ Container already running"

    echo ""
    update_codex_cli "$CONTAINER_NAME"

    # Copy OpenAI config if it exists locally
    if [ -d "$HOME/.openai" ]; then
        echo "  Copying OpenAI configuration..."
        docker cp "$HOME/.openai" "${CONTAINER_NAME}:/home/node/.openai" 2>/dev/null || true
    fi

    # Copy skills from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/skills" ]; then
        echo "  Copying skills..."
        docker-compose -p "$PROJECT_NAME" exec -T claude-code mkdir -p /home/node/.codex/skills
        docker cp "$SCRIPT_DIR/.claude/skills/." "${CONTAINER_NAME}:/home/node/.codex/skills/"
    fi

    # Copy commands from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/commands" ]; then
        echo "  Copying commands..."
        docker-compose -p "$PROJECT_NAME" exec -T claude-code mkdir -p /home/node/.codex/commands
        docker cp "$SCRIPT_DIR/.claude/commands/." "${CONTAINER_NAME}:/home/node/.codex/commands/"
    fi

    # Copy project .env file if it exists (autodex repo only).
    ENV_SOURCE="${PROJECT_ENV_FILE:-$SCRIPT_DIR/project.env}"
    if [ "$REPO_OVERRIDE" = "autodex" ] && [ -f "$ENV_SOURCE" ]; then
        if [ -n "$GIT_CLONE_DIR" ]; then
            REPO_DIR="$GIT_CLONE_DIR"
        elif [ -n "$GIT_REPO_URL" ]; then
            REPO_DIR=$(basename "$GIT_REPO_URL" .git)
        fi
        if [ -n "$REPO_DIR" ]; then
            ENV_DEST_DIR="${PROJECT_ENV_DEST:-$NPM_INSTALL_DIR}"
            if [ -n "$ENV_DEST_DIR" ]; then
                ENV_DEST="/workspace/$REPO_DIR/$ENV_DEST_DIR/.env"
            else
                ENV_DEST="/workspace/$REPO_DIR/.env"
            fi
            echo "  Copying project .env to $ENV_DEST..."
            docker cp "$ENV_SOURCE" "${CONTAINER_NAME}:${ENV_DEST}"
        fi
    fi

    echo "  Connecting to existing instance..."
    echo ""
    if [ "$USE_TMUX" = "true" ]; then
        # Fast re-attach: if the container already has a tmux session, attach
        # directly instead of re-running the full entrypoint (which re-checks
        # credentials, git status, etc. and can get stuck).
        if docker exec "$CONTAINER_NAME" tmux has-session -t llm-session 2>/dev/null; then
            echo "🔄 Reattaching to existing tmux session..."
            echo ""
            emit_desktop_input_ready_marker
            docker exec -it "$CONTAINER_NAME" tmux -u attach-session -d -t llm-session
        else
            # No tmux session — run entrypoint to start a fresh one
            docker exec $ENV_OVERRIDE -it "$CONTAINER_NAME" /entrypoint.sh codex
        fi
    else
        docker exec $ENV_OVERRIDE -it "$CONTAINER_NAME" /entrypoint.sh codex
    fi
else
    # Check if container exists but is stopped
    if docker ps -aq -f name="^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
        echo "✓ Container exists but stopped"
        echo "  Starting existing container..."
        docker start "$CONTAINER_NAME"

        echo ""
        update_codex_cli "$CONTAINER_NAME"
    else
        echo "✓ Creating new container..."
        docker-compose -p "$PROJECT_NAME" run -d --service-ports --name "$CONTAINER_NAME" $ENV_OVERRIDE $VOLUME_OVERRIDE claude-code tail -f /dev/null

        # Wait for initial repository setup to complete
        # Dependency installation will continue in background
        echo ""
        echo "⏳ Setting up repository..."
        echo ""

        # Follow logs until clone/pull is complete
        docker logs -f "$CONTAINER_NAME" 2>&1 | while IFS= read -r line; do
            echo "   $line"
            # Break when clone is complete - let dependencies install in background
            if echo "$line" | grep -q "Repository cloned successfully!"; then
                break
            fi
            # Break when pre-cloned repo is ready (pull completed)
            if echo "$line" | grep -q "Repository ready (pre-cloned)"; then
                break
            fi
            # Also handle case where no git repo is configured
            if echo "$line" | grep -q "No git repository configured"; then
                break
            fi
        done

        echo ""
        echo "✓ Repository ready"
        echo "  (Dependencies are installing in background)"

        echo ""
        update_codex_cli "$CONTAINER_NAME"
    fi

    echo ""

    # Copy OpenAI config if it exists locally
    if [ -d "$HOME/.openai" ]; then
        echo "  Copying OpenAI configuration..."
        docker cp "$HOME/.openai" "${CONTAINER_NAME}:/home/node/.openai" 2>/dev/null || echo "  (Could not copy OpenAI config, continuing anyway...)"
    fi

    # Copy skills from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/skills" ]; then
        echo "  Copying skills..."
        docker cp "$SCRIPT_DIR/.claude/skills/." "${CONTAINER_NAME}:/home/node/.codex/skills/" 2>/dev/null || echo "  (Could not copy skills, continuing anyway...)"
    fi

    # Copy commands from repo if they exist
    if [ -d "$SCRIPT_DIR/.claude/commands" ]; then
        echo "  Copying commands..."
        docker cp "$SCRIPT_DIR/.claude/commands/." "${CONTAINER_NAME}:/home/node/.codex/commands/" 2>/dev/null || echo "  (Could not copy commands, continuing anyway...)"
    fi

    # Copy project .env file if it exists (autodex repo only).
    ENV_SOURCE="${PROJECT_ENV_FILE:-$SCRIPT_DIR/project.env}"
    if [ "$REPO_OVERRIDE" = "autodex" ] && [ -f "$ENV_SOURCE" ]; then
        if [ -n "$GIT_CLONE_DIR" ]; then
            REPO_DIR="$GIT_CLONE_DIR"
        elif [ -n "$GIT_REPO_URL" ]; then
            REPO_DIR=$(basename "$GIT_REPO_URL" .git)
        fi
        if [ -n "$REPO_DIR" ]; then
            ENV_DEST_DIR="${PROJECT_ENV_DEST:-$NPM_INSTALL_DIR}"
            if [ -n "$ENV_DEST_DIR" ]; then
                ENV_DEST="/workspace/$REPO_DIR/$ENV_DEST_DIR/.env"
            else
                ENV_DEST="/workspace/$REPO_DIR/.env"
            fi
            echo "  Copying project .env to $ENV_DEST..."
            docker cp "$ENV_SOURCE" "${CONTAINER_NAME}:${ENV_DEST}" 2>/dev/null || echo "  (Could not copy project .env, continuing anyway...)"
        fi
    fi

    echo "  Launching Codex CLI..."
    echo ""
    docker exec $ENV_OVERRIDE -it "$CONTAINER_NAME" /entrypoint.sh codex
fi
